---
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

interface NavItem {
  href: string;
  label: string;
}

const navItems: NavItem[] = [
  { href: '/', label: '首页' },
  { href: '/timeline', label: '时间线' },
  { href: '/friends', label: '友链' },
  { href: '/about', label: '关于' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-background/80 backdrop-blur-xl border-b border-border/50 py-4">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-[1fr_auto_1fr] items-center">
    <a href="/" class="group flex items-center gap-3 justify-self-start">
      <div class="w-8 h-8 rounded-full overflow-hidden border border-primary/20 bg-secondary transition-transform duration-300 group-hover:scale-105 flex items-center justify-center">
        <img src="/avatar.jpg" alt="溪午" class="w-full h-full object-cover" />
      </div>
      <span class="text-foreground font-medium tracking-tight hidden sm:block">{SITE_TITLE}的博客</span>
    </a>

    <nav class="hidden md:flex items-center gap-8 justify-self-center">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`text-sm transition-colors duration-200 relative group ${
            currentPath === item.href
              ? 'text-foreground font-medium'
              : 'text-muted-foreground hover:text-foreground'
          }`}
        >
          {item.label}
          <span class="absolute -bottom-1 left-0 w-0 h-px bg-primary transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2 justify-self-end">
      <button
        id="search-btn"
        class="flex items-center gap-1.5 px-2.5 py-1.5 text-xs text-muted-foreground bg-muted/60 hover:bg-muted rounded-md border border-border/60 transition-colors duration-200"
        aria-label="搜索"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <span class="hidden sm:inline">搜索</span>
        <kbd class="hidden sm:inline-flex items-center ml-1 px-1 py-0.5 text-[10px] bg-muted border border-border rounded">Ctrl+K</kbd>
      </button>

      <button
        data-theme-toggle
        class="p-2 text-muted-foreground hover:text-foreground rounded-md hover:bg-muted/60 transition-colors duration-200"
        aria-label="切换主题"
      >
        <svg class="w-5 h-5 hidden dark:block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
        <svg class="w-5 h-5 block dark:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg>
      </button>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-muted-foreground hover:text-foreground rounded-md hover:bg-muted/60 transition-colors duration-200"
        aria-label="菜单"
      >
        <svg id="menu-icon" class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
        <svg id="close-icon" class="w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="md:hidden fixed inset-0 top-[72px] z-40 bg-background opacity-0 pointer-events-none transition-opacity duration-300">
  <nav class="flex flex-col items-center gap-6 pt-12">
    {navItems.map((item, i) => (
      <a
        href={item.href}
        class={`mobile-nav-item text-lg transition-colors duration-200 ${
          currentPath === item.href
            ? 'text-foreground font-medium'
            : 'text-muted-foreground hover:text-foreground'
        }`}
        style={`--stagger: ${i * 60}ms`}
      >
        {item.label}
      </a>
    ))}
  </nav>
</div>

<!-- Search Modal -->
<div id="search-modal" class="search-overlay fixed inset-0 z-[100] flex items-start justify-center pt-[20vh] bg-background/80 backdrop-blur-sm" style="display:none">
  <div id="search-card" class="w-full max-w-xl mx-4 bg-card border border-border rounded-xl shadow-2xl overflow-hidden" onclick="event.stopPropagation()">
    <div class="flex items-center border-b border-border px-4">
      <svg class="w-4 h-4 text-muted-foreground shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input id="search-modal-input" type="text" placeholder="搜索文章..." class="flex-1 px-3 py-3.5 bg-transparent text-foreground outline-none text-sm" />
      <kbd class="hidden sm:inline-flex items-center px-1.5 py-0.5 text-[10px] bg-muted border border-border rounded text-muted-foreground">ESC</kbd>
    </div>
    <div id="search-modal-results" class="max-h-80 overflow-y-auto p-2 text-sm text-muted-foreground text-center py-8">输入关键词搜索</div>
  </div>
</div>

<script>
  (function() {
    // Mobile menu
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (mobileMenuBtn) {
      mobileMenuBtn.addEventListener('click', () => {
        const isOpen = mobileMenu?.classList.toggle('opacity-100');
        mobileMenu?.classList.toggle('pointer-events-auto');
        menuIcon?.classList.toggle('hidden', !!isOpen);
        closeIcon?.classList.toggle('hidden', !isOpen);
        document.body.classList.toggle('overflow-hidden', !!isOpen);
      });
    }

    document.querySelectorAll('#mobile-menu .mobile-nav-item').forEach(item => {
      item.addEventListener('click', () => {
        mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      });
    });

    // Search modal
    const searchBtn = document.getElementById('search-btn');
    const searchModal = document.getElementById('search-modal');
    const searchInput = document.getElementById('search-modal-input');
    const searchResults = document.getElementById('search-modal-results');
    const searchCard = document.getElementById('search-card');

    let posts = [];
    let loaded = false;

    async function loadPosts() {
      if (loaded) return;
      try {
        const res = await fetch('/search-index.json');
        posts = await res.json();
        loaded = true;
      } catch (e) {}
    }

    function openSearch() {
      searchModal.style.display = 'flex';
      document.body.classList.add('overflow-hidden');
      searchInput.value = '';
      searchResults.innerHTML = '<div class="text-center py-8">输入关键词搜索</div>';
      setTimeout(() => searchInput.focus(), 50);
      loadPosts();
    }

    function closeSearch() {
      searchModal.style.display = 'none';
      document.body.classList.remove('overflow-hidden');
    }

    searchBtn?.addEventListener('click', openSearch);

    searchModal?.addEventListener('click', (e) => {
      if (!searchCard?.contains(e.target)) closeSearch();
    });

    searchInput?.addEventListener('input', () => {
      const q = searchInput.value.trim().toLowerCase();
      if (!q) {
        searchResults.innerHTML = '<div class="text-center py-8">输入关键词搜索</div>';
        return;
      }
      const matches = posts.filter(p =>
        p.title.toLowerCase().includes(q) ||
        p.description.toLowerCase().includes(q) ||
        (p.tags || []).some(t => t.toLowerCase().includes(q))
      );
      if (matches.length === 0) {
        searchResults.innerHTML = '<div class="text-center py-8">未找到相关文章</div>';
        return;
      }
      searchResults.innerHTML = matches.map(p => {
        const title = p.title.replace(/</g, '&lt;').replace(/>/g, '&gt;');
        const desc = p.description.replace(/</g, '&lt;').replace(/>/g, '&gt;');
        const tagsHtml = (p.tags || []).map(t =>
          '<span class="px-1.5 py-0.5 rounded text-[10px] bg-secondary text-secondary-foreground">' + t.replace(/</g, '&lt;') + '</span>'
        ).join('');
        return `<a href="/blog/${p.id}/" class="block p-3 rounded-lg hover:bg-muted/60 transition-colors group">
          <div class="font-medium text-foreground text-sm group-hover:text-primary transition-colors">${title}</div>
          <div class="text-xs text-muted-foreground mt-1 line-clamp-1">${desc}</div>
          <div class="flex gap-1 mt-1.5">${tagsHtml}</div>
        </a>`;
      }).join('');
    });

    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
      if (e.key === 'Escape' && searchModal?.style.display === 'flex') {
        closeSearch();
      }
    });
  })();
</script>

<style>
  #mobile-menu.opacity-100 .mobile-nav-item {
    animation: mobileItemIn 0.3s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--stagger, 0ms);
  }
  @keyframes mobileItemIn {
    0% { opacity: 0; transform: translateY(14px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .search-overlay { animation: overlayIn 0.15s ease-out; }
  @keyframes overlayIn {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }
</style>
