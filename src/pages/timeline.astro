---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const groupedByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
  const year = post.data.pubDate.getFullYear();
  if (!groupedByYear[year]) groupedByYear[year] = [];
  groupedByYear[year].push(post);
});

const years = Object.keys(groupedByYear).map(Number).sort((a, b) => b - a);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`时间线 - ${SITE_TITLE}`} description="文章归档时间线" />
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <Header />
    <main class="max-w-3xl mx-auto px-6 pt-24 pb-16">
      <h1 class="font-serif text-3xl font-bold text-foreground mb-12">时间线</h1>

      {posts.length === 0 ? (
        <p class="text-muted-foreground text-center py-20">暂无文章</p>
      ) : (
        <div class="relative">
          <!-- Main timeline line -->
          <div class="absolute left-[9px] top-3 bottom-0 w-px bg-border"></div>

          {years.map((year) => (
            <section class="mb-10">
              <!-- Year header -->
              <div class="flex items-center gap-4 mb-6">
                <div class="relative z-10 w-5 h-5 rounded-full bg-primary border-4 border-background shadow-[0_0_0_3px_var(--color-primary-cv)]"></div>
                <div class="flex items-baseline gap-3">
                  <h2 class="font-serif text-2xl font-bold text-foreground">{year}</h2>
                  <span class="text-sm text-muted-foreground">{groupedByYear[year].length} 篇</span>
                </div>
              </div>

              <div class="ml-10 space-y-3">
                {groupedByYear[year].map((post, i) => (
                  <a href={`/blog/${post.id}/`} class="block group relative pl-8 py-3 rounded-lg hover:bg-muted/40 transition-colors duration-200 -ml-10">
                    <!-- Item dot -->
                    <div class="absolute left-[5px] top-[18px] z-10 w-2 h-2 rounded-full border-2 border-border bg-background group-hover:border-primary group-hover:bg-primary transition-colors duration-200"></div>

                    <div class="flex items-baseline gap-3 flex-wrap">
                      <span class="text-xs text-muted-foreground shrink-0 font-mono">
                        {post.data.pubDate.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                      </span>
                      <span class="text-sm text-foreground group-hover:text-primary transition-colors duration-200">
                        {post.data.title}
                      </span>
                      {post.data.tags && post.data.tags.length > 0 && (
                        <span class="hidden sm:inline-flex gap-1 ml-auto">
                          {post.data.tags.map((tag) => (
                            <span class="px-1.5 py-0.5 rounded text-[10px] bg-secondary text-secondary-foreground">{tag}</span>
                          ))}
                        </span>
                      )}
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      )}
    </main>
    <Footer />
  </body>
</html>
