---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

interface FriendLink {
  name: string;
  url: string;
  avatar?: string;
  description: string;
}

const friends: FriendLink[] = [
  {
    name: '时歌的博客',
    url: 'https://www.lapis.cafe',
    avatar: 'https://www.lapis.cafe/avatar.webp',
    description: '理解以真实为本，但真实本身并不会自动呈现',
  },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`友链 - ${SITE_TITLE}`} description="友情链接" />
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <Header />
    <main class="max-w-4xl mx-auto px-6 pt-24 pb-16">
      <h1 class="font-serif text-3xl font-bold text-foreground mb-8">友链</h1>

      {friends.length === 0 ? (
        <div class="text-center py-20 text-muted-foreground">
          <p class="text-lg mb-2">暂无友链</p>
          <p class="text-sm">在 <code class="bg-muted px-1 py-0.5 rounded text-xs">src/pages/friends.astro</code> 的 <code class="bg-muted px-1 py-0.5 rounded text-xs">friends</code> 数组中添加友链</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {friends.map((friend) => (
            <a href={friend.url} target="_blank" rel="noopener noreferrer" class="block bg-card border border-border/50 rounded-xl p-5 hover:border-primary/30 hover:-translate-y-0.5 transition-all duration-200">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
                  {friend.avatar ? (
                    <img src={friend.avatar} alt={friend.name} class="w-full h-full rounded-full object-cover" />
                  ) : (
                    <span class="text-primary text-sm font-bold">{friend.name.charAt(0)}</span>
                  )}
                </div>
                <span class="text-sm font-medium text-foreground">{friend.name}</span>
              </div>
              <p class="text-xs text-muted-foreground line-clamp-2">{friend.description}</p>
            </a>
          ))}
        </div>
      )}

      <div class="mt-16 p-6 bg-card border border-border/50 rounded-xl">
        <h2 class="font-serif text-xl font-bold text-foreground mb-4">申请友链</h2>
        <p class="text-sm text-muted-foreground mb-4">欢迎交换友链，请通过邮件联系或按以下格式提供你的站点信息：</p>
        <div class="bg-muted/60 rounded-lg p-4 text-xs text-muted-foreground space-y-1 font-mono">
          <p>站点名称: {SITE_TITLE}</p>
          <p>站点地址: {Astro.site}</p>
          <p>站点描述: 随便写写东西</p>
          <p>RSS: {new URL('/rss.xml', Astro.site)}</p>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
