---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = allPosts.reduce((acc, post) => {
  const cat = post.data.category;
  if (cat) acc[cat] = (acc[cat] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const catEntries = Object.entries(categories).sort((a, b) => b[1] - a[1]);

const postsJson = JSON.stringify(allPosts.map(p => {
  const raw = (p.body || '').replace(/[#*`\[\]()>\-!\|~]/g, '').replace(/\s+/g, '');
  return {
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    pubDate: p.data.pubDate.toISOString(),
    tags: p.data.tags || [],
    category: p.data.category || '',
    chars: raw.length,
  };
}));
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-background text-foreground min-h-screen">
    <Header />
    <main class="max-w-6xl mx-auto px-6 pt-24 pb-16">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
        <aside class="order-2 lg:order-1 lg:w-80 shrink-0">
          <div class="sticky top-24 space-y-6">
            <div class="bg-card border border-border/50 rounded-xl p-5">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-12 h-12 rounded-full bg-primary/10 border border-primary/20 flex items-center justify-center overflow-hidden">
                  <img src="/avatar.jpg" alt={SITE_TITLE} class="w-full h-full object-cover" />
                </div>
                <div>
                  <p class="text-sm font-medium text-foreground">{SITE_TITLE}</p>
                  <p class="text-xs text-muted-foreground">个人博客</p>
                </div>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed">{SITE_DESCRIPTION}</p>
            </div>

            <div class="bg-card border border-border/50 rounded-xl p-5">
              <h3 class="text-sm font-semibold text-foreground mb-3">分类</h3>
              <div class="space-y-1">
                <button data-cat="" class="cat-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-lg text-sm hover:bg-muted/60 transition-colors active">
                  <span>全部</span>
                  <span class="text-xs text-muted-foreground">{allPosts.length}</span>
                </button>
                {catEntries.map(([cat, count]) => (
                  <button data-cat={cat} class="cat-btn w-full text-left flex items-center justify-between px-2 py-1.5 rounded-lg text-sm hover:bg-muted/60 transition-colors">
                    <span>{cat}</span>
                    <span class="text-xs text-muted-foreground">{count}</span>
                  </button>
                ))}
              </div>
            </div>
          </div>
        </aside>

        <div class="order-1 lg:order-2 flex-1">
          <div id="article-list" class="space-y-4"></div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<script define:vars={{ postsJson }}>
  const POSTS = JSON.parse(postsJson);
  const listEl = document.getElementById('article-list');
  const btns = document.querySelectorAll('.cat-btn');

  function render(posts) {
    if (posts.length === 0) {
      listEl.innerHTML = '<div class="text-center py-20 text-muted-foreground"><p class="text-lg mb-2">暂无文章</p></div>';
      return;
    }
    listEl.innerHTML = posts.map((p, i) => `
      <article class="group relative bg-card border border-border/50 rounded-xl p-5 article-enter hover:border-primary/30 transition-colors duration-200" style="animation-delay: ${i * 80}ms">
        <div class="flex gap-4 sm:gap-5">
          <div class="flex-1 min-w-0">
            <h3 class="font-serif text-lg sm:text-xl font-bold text-foreground mb-3 leading-tight group-hover:text-primary dark:group-hover:text-foreground transition-colors duration-75 flex items-start gap-2">
              <span class="w-1 h-6 shrink-0 bg-primary rounded-full mt-0.5"></span>
              <a href="/blog/${p.id}/" class="flex-1 min-w-0">${esc(p.title)}</a>
            </h3>
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted-foreground mb-3">
              <time>${new Date(p.pubDate).toLocaleDateString('zh-CN',{year:'numeric',month:'2-digit',day:'2-digit'})}</time>
              <span>${p.chars} 字</span>
              ${(p.tags||[]).map(t => `<span class="px-1.5 py-0.5 rounded text-[10px] bg-secondary text-secondary-foreground">${esc(t)}</span>`).join('')}
            </div>
            <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">${esc(p.description)}</p>
          </div>
        </div>
      </article>
    `).join('');
  }

  function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  function setActive(btn) {
    btns.forEach(b => b.classList.remove('font-semibold', 'text-primary'));
    btn.classList.add('font-semibold', 'text-primary');
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      render(cat ? POSTS.filter(p => p.category === cat) : POSTS);
      setActive(btn);
    });
  });

  render(POSTS);
  setActive(document.querySelector('.cat-btn[data-cat=""]'));
</script>
